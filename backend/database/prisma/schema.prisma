generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// -------------------- Permissions & Groups START

model Permission {
  id     String                      @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  value  String                      @id
  ///
  groups GroupPermissionAssignment[]

  @@map("permission")
}

enum GroupType {
  ROOT
  PRESIDENT
  AUDITORIUM_SECRETARY
  SHOW_MANAGER
  SALES_AGENT
  FINANCIAL_CLERK
  SPECTATOR
}

model Group {
  id          String                      @id @default(dbgenerated("gen_random_uuid()"))
  type        GroupType                   @unique
  description String?
  ///
  permissions GroupPermissionAssignment[]
  user        GroupUserAssignment[]

  @@map("group")
}

model GroupPermissionAssignment {
  groupId      String     @map("group_id") @db.Uuid
  permissionId String     @map("permission_id")
  ///
  group        Group      @relation(fields: [groupId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  permission   Permission @relation(fields: [permissionId], references: [value], onDelete: Restrict, onUpdate: Restrict)

  @@id([permissionId, groupId])
  @@map("group_permission_assignment")
}

model GroupUserAssignment {
  groupId String      @map("group_id") @db.Uuid
  userId  String      @map("user_id") @db.Uuid
  ///
  group   Group       @relation(fields: [groupId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  user    UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@id([groupId, userId])
  @@map("group_user_assignment")
}

// -------------------- Permissions & Groups END

// -------------------- Users START

model UserProfile {
  id             String                @id @db.Uuid
  email          String                @unique
  hashedPassword String                @map("hashed_password")
  createdAt      DateTime              @default(dbgenerated("now()")) @map("created_at")
  ///
  groups         GroupUserAssignment[]
  created_events Event[]
  created_shows  Show[]

  @@map("user_profile")
}

// -------------------- Users END

// -------------------- Events & Shows START

model Event {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdByUserId String      @map("created_by_user_id") @db.Uuid
  name            String
  description     String?
  thumbnailUrl    String?     @map("thumbnail_url")
  createdAt       DateTime    @default(dbgenerated("now()")) @map("created_at")
  ///
  createdByUser   UserProfile @relation(fields: [createdByUserId], references: [id], onDelete: NoAction, onUpdate: Restrict)
  shows           Show[]

  @@map("event")
}

model Show {
  id                String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId           String               @map("event_id") @db.Uuid
  createdByUserId   String               @map("created_by_user_id") @db.Uuid
  name              String
  description       String?
  thumbnailUrl      String?              @map("thumbnail_url")
  startingAt        DateTime             @map("starting_at")
  endingAt          DateTime             @map("ending_at")
  ordinarySeatPrice Float                @map("ordinary_seat_price")
  balconySeatPrice  Float                @map("balcony_seat_price")
  createdAt         DateTime             @default(dbgenerated("now()")) @map("created_at")
  ///
  createdByUser     UserProfile          @relation(fields: [createdByUserId], references: [id], onDelete: NoAction, onUpdate: Restrict)
  event             Event                @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  seatAssignments   ShowSeatAssignment[]

  @@map("show")
}

// -------------------- Events & Shows END

// -------------------- Seats START

enum SeatType {
  ORDINARY
  BALCONY
}

model Seat {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  number          String               @unique
  seatType        SeatType             @map("seat_type")
  ///
  showAssignments ShowSeatAssignment[]

  @@map("seat")
}

model ShowSeatAssignment {
  showId String @map("show_id") @db.Uuid
  seatId String @map("seat_id") @db.Uuid
  ///
  show   Show   @relation(fields: [showId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  seat   Seat   @relation(fields: [seatId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@id([showId, seatId])
  @@map("show_seat_assignment")
}

// -------------------- Seats END

